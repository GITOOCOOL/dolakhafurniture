"></script><script src=\"/_next/static/chunks/a91304223104a0a3.js\" async=\"\"></script><script src=\"/_next/static/chunks/d82a21c6fe65ed43.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><style>\n          @keyframes boho-glow {\n            0%, 100% { filter: drop-shadow(0 0 2px rgba(163, 87, 58, 0.4)); }\n            50% { filter: drop-shadow(0 0 8px rgba(223, 145, 82, 0.6)); }\n          }\n          .neon-hover:hover { animation: boho-glow 2s infinite; }\n        </style><script src=\"/_next/static/chunks/a6dad97d9634a72d.js\" noModule=\"\"></script></head><body class=\"cormorant_garamond_8b4d25a0-module__jNluqa__variable montserrat_fcc07174-module__p22edW__variable antialiased bg-[#fdfaf5] text-[#3d2b1f] font-sans overflow-x-hidden w-full max-w-full\"><div hidden=\"\"><!--$--><!--/$--></div><header class=\"sticky top-0 z-50 w-full bg-[#fdfaf5] border-b border-[#e5dfd3] shadow-[0_2px_10px_rgba(0,0,0,0.02)]\"><div class=\"container mx-auto px-2 md:px-6 w-full flex items-center justify-between py-3 md:py-4 gap-2\"><div class=\"flex-none flex items-center gap-2 md:gap-4\"><button class=\"w-[38px] h-[38px] flex items-center justify-center text-[#3d2b1f] hover:text-[#a3573a] transition-all -ml-1 md:-ml-2 flex-shrink-0\" aria-label=\"Menu\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"26\" height=\"26\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu md:w-7 md:h-7\" aria-hidden=\"true\"><path d=\"M4 5h16\"></path><path d=\"M4 12h16\"></path><path d=\"M4 19h16\"></path></svg></button><div class=\"bg-[#eee9df] rounded-full shadow-sm\"><a class=\"h-8 md:h-[48px] flex items-center px-4 md:px-6 text-[10px] md:text-[12px] font-bold uppercase tracking-[0.2em] text-[#a3573a] bg-[#eee9df] shadow-sm hover:bg-[#d9d1c1] rounded-full transition-all whitespace-nowrap flex-shrink-0 underline underline-offset-4 decoration-1\" href=\"/shop\">Shop</a></div></div><div class=\"flex-1 flex items-center justify-center min-w-0\"><a class=\"flex items-center gap-3 group flex-shrink-0\" href=\"/\"><div class=\"relative flex-shrink-0 w-14 h-14 md:w-20 md:h-20 flex items-center justify-center\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"w-full h-full text-[#a3573a] opacity-20 absolute transition-transform duration-700 group-hover:scale-110\"><path d=\"M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z\"></path></svg><img src=\"/logo.png\" alt=\"Home\" style=\"width:22px;height:22px\" class=\"md:w-11 md:h-11 aspect-square object-contain transition-transform duration-700 group-hover:rotate-6 relative z-10 mt-1\"/></div><span class=\"hidden lg:block text-2xl xl:text-3xl font-serif italic tracking-tight text-[#3d2b1f]\">Dolakha<span class=\"text-[#a3573a]\">.</span>Furniture</span></a></div><div class=\"flex-none flex items-center justify-end\"><div class=\"w-20 h-8 bg-[#fdfaf5] animate-pulse rounded-full border border-[#e5dfd3]\"></div></div></div><div class=\"hidden md:flex container mx-auto px-6 pb-3 justify-center\"><div class=\"flex gap-6 lg:gap-10 opacity-50\"><div class=\"h-4 w-16 bg-[#e5dfd3] animate-pulse rounded\"></div><div class=\"h-4 w-16 bg-[#e5dfd3] animate-pulse rounded\"></div><div class=\"h-4 w-16 bg-[#e5dfd3] animate-pulse rounded\"></div><div class=\"h-4 w-16 bg-[#e5dfd3] animate-pulse rounded\"></div><div class=\"h-4 w-16 bg-[#e5dfd3] animate-pulse rounded\"></div></div></div></header><main class=\"min-h-screen w-full relative\"><div class=\"bg-[#fdfaf5] min-h-screen pt-32 pb-20 font-sans text-[#3d2b1f]\"><div class=\"container mx-auto px-6\"><header class=\"mb-24 text-center max-w-4xl mx-auto\"><p class=\"text-[10px] font-bold uppercase tracking-[0.4em] text-[#a3573a] mb-6\">Our Heritage &amp; Vision</p><h1 class=\"text-6xl md:text-8xl font-serif italic font-medium text-[#3d2b1f] leading-tight mb-12\">The Story of Dolakha<span class=\"text-[#a3573a]\">.</span></h1><div class=\"h-[1px] w-24 bg-[#a3573a] mx-auto opacity-50\"></div></header><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-20 items-center mb-40\"><div class=\"space-y-10 order-2 lg:order-1\"><h2 class=\"text-4xl md:text-5xl font-serif italic font-medium text-[#3d2b1f] leading-snug\">Born in Kathmandu, <br/>Inspired by Tradition.</h2><div class=\"space-y-6\"><p class=\"text-lg text-[#a89f91] leading-relaxed font-light\">Established as a leading furniture designer and supplier in the heart of Kathmandu, Dolakha Furniture was founded with a singular purpose: to bring the strength and beauty of artisanal craftsmanship into every Nepali home.</p><p class=\"text-[#a3573a] italic font-serif text-2xl leading-relaxed\">&quot;Quality product with beauty is in our mind.&quot;</p></div></div><div class=\"order-1 lg:order-2 aspect-[4/5] bg-[#e5dfd3] rounded-[4rem] overflow-hidden shadow-sm relative group\"><img src=\"/hero.jpg\" alt=\"Dolakha Craftsmanship\" class=\"object-cover w-full h-full opacity-90 sepia-[0.3] hover:sepia-0 transition-all duration-1000\"/><div class=\"absolute inset-0 bg-[#a3573a]/5 mix-blend-multiply\"></div></div></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-16 border-y border-[#e5dfd3] border-dotted py-24 mb-40\"><div class=\"space-y-4\"><span class=\"text-[#a3573a] font-serif italic text-4xl\">01.</span><h3 class=\"text-lg font-serif italic font-semibold text-[#3d2b1f]\">Smart Design</h3><p class=\"text-sm text-[#a89f91] leading-relaxed font-light\">From our famous metallic swings to versatile plant stands, we blend iron and wood using smart ideas to maximize your home&#x27;s potential.</p></div><div class=\"space-y-4\"><span class=\"text-[#a3573a] font-serif italic text-4xl\">02.</span><h3 class=\"text-lg font-serif italic font-semibold text-[#3d2b1f]\">Enduring Quality</h3><p class=\"text-sm text-[#a89f91] leading-relaxed font-light\">Every product—whether a bed, daraz, or console table—is built to be as strong as it is good-looking, ensuring it lasts for generations.</p></div><div class=\"space-y-4\"><span class=\"text-[#a3573a] font-serif italic text-4xl\">03.</span><h3 class=\"text-lg font-serif italic font-semibold text-[#3d2b1f]\">Personal Touch</h3><p class=\"text-sm text-[#a89f91] leading-relaxed font-light\">Based in Samakhusi, we pride ourselves on direct connection—delivering personally to your doorstep across Kathmandu.</p></div></div><section class=\"bg-[#1a1c13] text-[#fdfaf5] rounded-[5rem] p-12 md:p-24 text-center\"><h2 class=\"text-4xl md:text-6xl font-serif italic font-medium mb-10 leading-snug\">Visit Our Samakhusi <br/> Showroom<span class=\"text-[#df9152]\">.</span></h2><p class=\"text-[#e2e8da] mb-12 max-w-xl mx-auto text-xl italic font-serif leading-relaxed\">&quot;Experience the texture and strength of our pieces in person. We are ready to deliver beauty to your home.&quot;</p><div class=\"flex flex-col md:flex-row gap-6 justify-center\"><a class=\"bg-[#fdfaf5] text-[#1a1c13] px-10 py-5 rounded-full font-bold uppercase tracking-widest hover:bg-[#a3573a] hover:text-white transition-all\" href=\"/shop\">Explore Archive</a><a href=\"https://www.facebook.com/dolakhafurniture/\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"border border-[#fdfaf5]/20 text-[#fdfaf5] px-10 py-5 rounded-full font-bold uppercase tracking-widest hover:border-[#a3573a] hover:text-[#a3573a] transition-all\">Message Us</a></div></section></div></div><!--$--><!--/$--></main><footer class=\"border-t border-[#e5dfd3] border-dotted bg-[#1a1c13] text-[#e2e8da] py-20 w-full\"><div class=\"container mx-auto px-6\"><div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 text-center md:text-left\"><div class=\"lg:col-span-2\"><h3 class=\"text-[#fdfaf5] text-3xl font-serif italic mb-6 leading-relaxed\">&quot;Sustainably sourced, <br/> thoughtfully crafted.&quot;</h3><p class=\"text-[#a89f91] text-sm font-light italic leading-relaxed\">Each piece is a testament to our commitment to quality and sustainability. Our other platforms are just a click away, where you can explore more of our story and collections.</p><br/><div class=\"flex justify-center md:justify-start gap-8 text-[11px] uppercase tracking-[0.2em] font-medium\"><a href=\"https://facebook.com/dolakhafurniture\" target=\"_blank\" class=\"hover:text-[#df9152] transition-colors\">Facebook</a><a href=\"https://instagram.com/dolakhafurnituredesign\" target=\"_blank\" class=\"hover:text-[#df9152] transition-colors\">Instagram</a><a href=\"https://tiktok.com/@dolakhafurniture\" target=\"_blank\" class=\"hover:text-[#df9152] transition-colors\">TikTok</a></div></div><div class=\"md:ml-auto w-full\"><p class=\"text-[#fdfaf5] text-xs font-serif italic mb-4\">Join our Socials</p><div class=\"flex border-b border-[#3d2b1f] pb-2 max-w-xs mx-auto md:mx-0\"><input type=\"text\" placeholder=\"EMAIL ADDRESS\" class=\"bg-transparent text-xs w-full outline-none placeholder:text-[#a89f91] placeholder:text-[10px] tracking-widest\"/><button class=\"text-[#df9152] font-serif italic\">→</button></div></div></div></div></footer><script src=\"/_next/static/chunks/2a75c689c90d362b.js\" id=\"_R_\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0])</script><script>self.__next_f.push([1,\"1:\\\"$Sreact.fragment\\\"\\n2:I[92825,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"ClientSegmentRoot\\\"]\\n3:I[53642,[\\\"/_next/static/chunks/47679ee018b5a958.js\\\",\\\"/_next/static/chunks/5212a1df4685ef35.js\\\",\\\"/_next/static/chunks/1a61ae94af428c79.js\\\",\\\"/_next/static/chunks/a91304223104a0a3.js\\\",\\\"/_next/static/chunks/d82a21c6fe65ed43.js\\\"],\\\"default\\\"]\\n4:I[39756,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fbe.js\\\"],\\\"default\\\"]\\n5:I[37457,[\\\"/_next/static/chunks/ff1a16fafef87110.js\\\",\\\"/_next/static/chunks/d2be314c3ece3fb